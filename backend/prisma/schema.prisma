generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  moodleId  String   @unique
  password  String
  name      String
  role      Role     @default(STUDENT)
  division  String
  batch     String
  createdAt DateTime @default(now())

  tasks         Task[]           // Tasks created by this user
  notes         Note[]
  completions   TaskCompletion[] // Tasks completed by this user
  announcements Announcement[]   // Announcements created by this user
  requests      Request[]        // Requests created by this user
}

enum Role {
  STUDENT
  ADMIN
}

model Subject {
  id    Int    @id @default(autoincrement())
  name  String @unique

  notes Note[]
  tasks Task[]
}

model Note {
  id            Int          @id @default(autoincrement())
  title         String
  description   String?
  fileName      String
  fileSize      Float
  category      NoteCategory
  downloadCount Int          @default(0)
  uploadedAt    DateTime     @default(now())

  subject      Subject @relation(fields: [subjectId], references: [id])
  subjectId    Int

  uploadedBy   User @relation(fields: [uploadedById], references: [id])
  uploadedById Int
}

enum NoteCategory {
  ASSIGNMENT
  EXPERIMENT
  CLASS_NOTES
}

model Task {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  dueDate     DateTime
  status      TaskStatus @default(PENDING)
  isAdmin     Boolean    @default(false)
  forBatch    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  subject   Subject @relation(fields: [subjectId], references: [id])
  subjectId Int

  createdBy   User @relation(fields: [createdById], references: [id])
  createdById Int

  completions TaskCompletion[]
}

enum TaskStatus {
  PENDING
  COMPLETED
}

model TaskCompletion {
  id          Int      @id @default(autoincrement())
  taskId      Int
  userId      Int
  completedAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([taskId, userId])
}

model Announcement {
  id          Int      @id @default(autoincrement())
  content     String
  type        String   // IMPORTANT or OPTIONAL
  createdAt   DateTime @default(now())
  createdById Int
  createdBy   User     @relation(fields: [createdById], references: [id])
}

model Channel {
  id        Int       @id @default(autoincrement())
  name      String
  scope     String    // DEPARTMENT, DIVISION, or BATCH
  createdAt DateTime  @default(now())
  
  requests  Request[]
}

model Request {
  id          Int       @id @default(autoincrement())
  content     String
  status      String    @default("PENDING")
  createdAt   DateTime  @default(now())
  channelId   Int
  createdById Int
  
  channel   Channel @relation(fields: [channelId], references: [id])
  createdBy User    @relation(fields: [createdById], references: [id])
}