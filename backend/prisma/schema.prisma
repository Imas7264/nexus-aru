generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  moodleId   String   @unique
  password   String
  name       String
  role       Role     @default(STUDENT)
  division   String
  batch      String
  createdAt  DateTime @default(now())

  files         File[]
  tasks         Task[]
  announcements Announcement[]
  requests      Request[]
}

enum Role {
  STUDENT
  ADMIN
}

model Subject {
  id    Int    @id @default(autoincrement())
  name  String @unique

  files File[]
  tasks Task[]
}

model File {
  id          Int          @id @default(autoincrement())
  name        String
  size        Float
  description String?
  category    FileCategory
  uploadedAt  DateTime     @default(now())

  subject   Subject @relation(fields: [subjectId], references: [id])
  subjectId Int

  uploadedBy   User @relation(fields: [uploadedById], references: [id])
  uploadedById Int
}

enum FileCategory {
  ASSIGNMENTS
  EXPERIMENTS
  NOTES
  OTHER
}

model Task {
  id        Int        @id @default(autoincrement())
  name      String
  dueDate   DateTime
  status    TaskStatus @default(PENDING)
  isAdmin   Boolean    @default(false)
  createdAt DateTime   @default(now())

  subject   Subject @relation(fields: [subjectId], references: [id])
  subjectId Int

  user   User @relation(fields: [userId], references: [id])
  userId Int
}

enum TaskStatus {
  PENDING
  COMPLETED
}

model Announcement {
  id        Int              @id @default(autoincrement())
  content   String
  type      AnnouncementType
  createdAt DateTime         @default(now())

  createdBy   User @relation(fields: [createdById], references: [id])
  createdById Int
}

enum AnnouncementType {
  IMPORTANT
  OPTIONAL
}

model Channel {
  id    Int         @id @default(autoincrement())
  name  String      @unique
  scope ChannelScope

  requests Request[]
}

enum ChannelScope {
  DEPARTMENT
  DIVISION
  BATCH
}

model Request {
  id        Int        @id @default(autoincrement())
  content   String
  status    TaskStatus @default(PENDING)
  createdAt DateTime   @default(now())

  channel   Channel @relation(fields: [channelId], references: [id])
  channelId Int

  createdBy   User @relation(fields: [createdById], references: [id])
  createdById Int
}