generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  moodleId  String   @unique
  password  String
  name      String
  role      Role     @default(STUDENT)
  division  String
  batch     String
  createdAt DateTime @default(now())

  // Notes & Tasks codebase
  notes         Note[]
  completions   TaskCompletion[]

  // Shared
  tasks         Task[]

  // Requests & Announcements codebase
  announcements Announcement[]
  requests      Request[]
}

enum Role {
  STUDENT
  ADMIN
}

// ─────────────────────────────────────────
// SUBJECT
// ─────────────────────────────────────────

model Subject {
  id   Int    @id @default(autoincrement())
  name String @unique

  notes Note[]
  tasks Task[]
}

// ─────────────────────────────────────────
// NOTE (from notes/tasks codebase)
// Kept as Note with NoteCategory since that
// codebase uses it — File model was the
// equivalent in the other repo
// ─────────────────────────────────────────

model Note {
  id            Int          @id @default(autoincrement())
  title         String
  description   String?
  fileName      String
  fileSize      Float
  category      NoteCategory
  downloadCount Int          @default(0)
  uploadedAt    DateTime     @default(now())

  subject      Subject @relation(fields: [subjectId], references: [id])
  subjectId    Int

  uploadedBy   User @relation(fields: [uploadedById], references: [id])
  uploadedById Int
}

enum NoteCategory {
  ASSIGNMENT
  EXPERIMENT
  CLASS_NOTES
}

// ─────────────────────────────────────────
// TASK (merged — kept richer version from
// notes/tasks codebase, added forBatch,
// description, updatedAt, and completions)
// ─────────────────────────────────────────

model Task {
  id          Int        @id @default(autoincrement())
  title       String
  description String?
  dueDate     DateTime
  status      TaskStatus @default(PENDING)
  isAdmin     Boolean    @default(false)
  forBatch    String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  subject   Subject @relation(fields: [subjectId], references: [id])
  subjectId Int

  createdBy   User @relation(fields: [createdById], references: [id])
  createdById Int

  completions TaskCompletion[]
}

enum TaskStatus {
  PENDING
  COMPLETED
}

model TaskCompletion {
  id          Int      @id @default(autoincrement())
  taskId      Int
  userId      Int
  completedAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([taskId, userId])
}

// ─────────────────────────────────────────
// ANNOUNCEMENT (from requests/announcements codebase)
// ─────────────────────────────────────────

model Announcement {
  id        Int              @id @default(autoincrement())
  content   String
  type      AnnouncementType
  createdAt DateTime         @default(now())

  createdBy   User @relation(fields: [createdById], references: [id])
  createdById Int
}

enum AnnouncementType {
  IMPORTANT
  OPTIONAL
}

// ─────────────────────────────────────────
// CHANNEL + REQUEST (from requests/announcements codebase)
// ─────────────────────────────────────────

model Channel {
  id    Int          @id @default(autoincrement())
  name  String       @unique
  scope ChannelScope

  requests Request[]
}

enum ChannelScope {
  DEPARTMENT
  DIVISION
  BATCH
}

model Request {
  id        Int        @id @default(autoincrement())
  content   String
  status    TaskStatus @default(PENDING)
  createdAt DateTime   @default(now())

  channel   Channel @relation(fields: [channelId], references: [id])
  channelId Int

  createdBy   User @relation(fields: [createdById], references: [id])
  createdById Int
}
